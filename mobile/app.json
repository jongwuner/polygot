{
  "expo": {
    "name": "Polyglot",
    "slug": "polyglot",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "polyglot",
    "newArchEnabled": true,
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gradylee.polyglot"
    },
    "android": {
      "package": "com.gradylee.polyglot",
      "adaptiveIcon": {
        "backgroundColor": "#1f1d1a"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-build-properties",
      "expo-document-picker",
      [
        "llama.rn",
        {
          "enableEntitlements": true,
          "entitlementsProfile": "production",
          "forceCxx20": true,
          "enableOpenCLAndHexagon": true
        }
      ]
    ]
  }
}
